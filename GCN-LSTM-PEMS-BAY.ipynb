   "source": [
    "X = []\n",
    "y = []\n",
    "\n",
    "sequence_length = 12\n",
    "\n",
    "for i in range(\n",
    "    len(traffic_scaled)\n",
    "    - sequence_length\n",
    "):\n",
    "\n",
    "    X.append(\n",
    "        traffic_scaled[\n",
    "            i:i+sequence_length\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    y.append(\n",
    "        traffic_scaled[\n",
    "            i+sequence_length\n",
    "        ]\n",
    "    )\n",
    "\n",
    "X = np.array(X)\n",
    "y = np.array(y)\n",
    "\n",
    "print(X.shape)\n",
    "print(y.shape)"
   ]
  },
  {
