   "outputs": [],
   "source": [
    "split = int(\n",
    "    len(X) * 0.8\n",
    ")\n",
    "\n",
    "X_train = X[:split]\n",
    "X_test = X[split:]\n",
    "\n",
    "y_train = y[:split]\n",
    "y_test = y[split:]"
   ]
  },
  {
